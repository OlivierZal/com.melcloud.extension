{
  "name": "com.melcloud.extension",
  "version": "24.5.0",
  "description": "Extension for MELCloud Homey App",
  "homepage": "https://github.com/OlivierZal/com.melcloud.extension/",
  "bugs": {
    "url": "https://github.com/OlivierZal/com.melcloud.extension/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlivierZal/com.melcloud.extension.git"
  },
  "license": "GPL-3.0-only",
  "author": "Olivier Zalmanski",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "npm run build:assets && node ./node_modules/@typescript/native/bin/tsc --project tsconfig.build.json",
    "build:assets": "node scripts/bundle.mjs",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "github:push": "npm run homey:validate && npm run lint:fix && npm run format:fix && git push",
    "homey:install": "npx homey app install",
    "homey:publish": "npx homey app publish",
    "homey:start": "npx homey app run --remote",
    "homey:validate": "npx homey app validate --level=publish",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "test": "vitest run",
    "test:coverage": "npm test -- --coverage",
    "typecheck": "node ./node_modules/@typescript/native/bin/tsc --noEmit"
  },
  "dependencies": {
    "homey-api": "^3.19.1",
    "temporal-polyfill": "^1.0.1"
  },
  "devDependencies": {
    "@eslint/css": "^1.4.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "@html-eslint/eslint-plugin": "^0.64.0",
    "@html-eslint/parser": "^0.64.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/homey": "npm:homey-apps-sdk-v3-types@^0.3.12",
    "@types/node": "^26.1.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.11",
    "eslint-plugin-package-json": "^1.5.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-unicorn": "^71.1.0",
    "eslint-plugin-yml": "^3.6.0",
    "homey-apps-sdk-v3-types": "^0.3.12",
    "jiti": "^2.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.9.5",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.62",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
