{
  "name": "com.melcloud.extension",
  "version": "23.0.1",
  "description": "Extension for MELCloud Homey App",
  "repository": {
    "type": "git",
    "url": "https://github.com/OlivierZal/com.melcloud.extension.git"
  },
  "license": "GPL-3.0-only",
  "author": "Olivier Zalmanski",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./app.mts"
  },
  "files": [
    ".homeybuild/"
  ],
  "scripts": {
    "build": "npm run prepare && tsc",
    "format": "prettier . --check",
    "format:docs": "prettier README.md --ignore-path --write",
    "format:fix": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "npm run format:docs && npm run lint:fix && npm run format:fix"
  },
  "dependencies": {
    "homey-api": "^3.17.4"
  },
  "devDependencies": {
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.1.0",
    "@eslint/markdown": "^7.5.1",
    "@html-eslint/eslint-plugin": "^0.58.1",
    "@html-eslint/parser": "^0.58.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/homey": "npm:homey-apps-sdk-v3-types@^0.3.12",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260317.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-package-json": "^0.91.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-yml": "^3.3.1",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
